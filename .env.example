APP_NAME=pulse-api
APP_VERSION=0.1.0
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Use a local Postgres role that can create the pg-boss schema.
DATABASE_URL=postgresql://your-local-db-user@localhost:5432/pulse_platform_dev
PG_BOSS_CONNECTION_STRING=postgresql://your-local-db-user@localhost:5432/pulse_platform_dev
PGBOSS_SCHEMA=pgboss
PGBOSS_ARCHIVE_SECONDS=604800
PGBOSS_DELETE_AFTER_SECONDS=2592000
PGBOSS_MONITOR_INTERVAL_SECONDS=5
PGBOSS_POLLING_INTERVAL_SECONDS=2
PGBOSS_DEAD_LETTER_QUEUE=pulse.dead-letter

ACUMATICA_BASE_URL=https://example.acumatica.local
ACUMATICA_API_VERSION=24.100.001
ACUMATICA_COMPANY=Dynamic AQS
ACUMATICA_USERNAME=svc-pulse
ACUMATICA_PASSWORD=replace-me
ACUMATICA_ACCESS_TOKEN=
MIGRATION_ADMIN_TOKEN=replace-with-strong-admin-token
